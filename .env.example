# Discord bot token
DISCORD__TOKEN=your_token_here

# General database information - the bot will use this to create a connection string to any MySQL instance
DB__HOST=localhost
DB__PORT=3306
DB__DATABASE=dbname
DB__USER=username
DB__PASSWORD=userpass

# Reaction score module
# Baseline role is assigned when no tier range matches.
REACTIONSCORE__BASELINEROLEID=123456789012345678

# Role tiers (up to 6 loaded, expected 6)
REACTIONSCORE__ROLETIERS__0__ROLEID=223456789012345678
REACTIONSCORE__ROLETIERS__0__MINSCORE=-999
REACTIONSCORE__ROLETIERS__0__MAXSCORE=-51
REACTIONSCORE__ROLETIERS__1__ROLEID=323456789012345678
REACTIONSCORE__ROLETIERS__1__MINSCORE=-50
REACTIONSCORE__ROLETIERS__1__MAXSCORE=-21
REACTIONSCORE__ROLETIERS__2__ROLEID=423456789012345678
REACTIONSCORE__ROLETIERS__2__MINSCORE=-20
REACTIONSCORE__ROLETIERS__2__MAXSCORE=-1
REACTIONSCORE__ROLETIERS__3__ROLEID=523456789012345678
REACTIONSCORE__ROLETIERS__3__MINSCORE=1
REACTIONSCORE__ROLETIERS__3__MAXSCORE=20
REACTIONSCORE__ROLETIERS__4__ROLEID=623456789012345678
REACTIONSCORE__ROLETIERS__4__MINSCORE=21
REACTIONSCORE__ROLETIERS__4__MAXSCORE=50
REACTIONSCORE__ROLETIERS__5__ROLEID=723456789012345678
REACTIONSCORE__ROLETIERS__5__MINSCORE=51
REACTIONSCORE__ROLETIERS__5__MAXSCORE=999

# Add emoji mappings in Discord with:
# /reaction-score add-emoji emoji:<emoji> score:<-5..5>
